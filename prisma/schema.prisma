generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                String              @id @default(cuid())
  name              String
  ownerName         String
  phone             String              @unique
  whatsappNumber    String
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEnd   DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Working Hours
  workingHours      String?             // JSON: per-day open/close/active
  isAlwaysOpen      Boolean             @default(true)

  // Store Customization
  logoUrl           String?             // Store logo URL
  primaryColor      String?             @default("#f5c842") // Gold theme default
  secondaryColor    String?             @default("#1a1a22") // Dark card default
  backgroundColor   String?             @default("#0f0f13") // Dark bg default
  textColor         String?             @default("#ffffff") // White text default
  accentColor       String?             @default("#fde98a") // Light gold accent
  fontFamily        String?             @default("Cairo")   // Default Arabic font
  
  // Relations
  products          Product[]
  orders            Order[]
  sessions          BotSession[]
  messages          Message[]
  whatsappSession   WhatsAppSession?

  @@map("shops")
}

model Product {
  id          String   @id @default(cuid())
  shopId      String
  name        String
  price       Float
  description String?
  imageUrl    String?  // Product image URL
  isAvailable Boolean  @default(true)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NEW FIELDS ONLY:
  stock         Int?      // null = unlimited, 0 = out of stock
  variants      String?   // JSON array of variant groups
  variantImages String?   // JSON: {"أحمر": "/uploads/red.jpg"}

  // Relations
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("products")
}

model Order {
  id             String      @id @default(cuid())
  shopId         String
  customerPhone  String
  whatsappNumber String?     // WhatsApp JID for matching
  customerName   String
  customerAddress String?
  status         OrderStatus @default(PENDING)
  totalPrice     Float
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  shop           Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  // NEW FIELD ONLY:
  variantInfo String?   // stores chosen variant as text

  // Relations
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Will be hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model BotSession {
  id        String   @id @default(cuid())
  shopId    String
  sessionId String   @unique
  status    String   @default("disconnected")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("bot_sessions")
}

model Message {
  id        String   @id @default(cuid())
  shopId    String
  from      String
  to        String
  body      String
  type      String   @default("text")
  direction Direction
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  TRIAL
  ACTIVE
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DELIVERED
}

enum Direction {
  INCOMING
  OUTGOING
}

model WhatsAppSession {
  id        String   @id
  shopId    String   @unique
  creds     String   @db.Text
  keys      String   @db.Text
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("whatsapp_sessions")
}
