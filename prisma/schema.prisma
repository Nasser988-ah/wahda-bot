generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                String              @id @default(cuid())
  name              String
  ownerName         String
  phone             String              @unique
  whatsappNumber    String
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEnd   DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Working Hours
  workingHours      String?             // JSON: per-day open/close/active
  isAlwaysOpen      Boolean             @default(true)

  // Wholesale Mode
  isWholesale       Boolean             @default(false)

  // Bot Type
  shopType          String              @default("traditional") // "traditional" | "custom"
  botType           String?             // null | "isp" | future types
  password          String?             // hashed password for custom bot clients

  // Store Customization
  logoUrl           String?             // Store logo URL
  primaryColor      String?             @default("#f5c842") // Gold theme default
  secondaryColor    String?             @default("#1a1a22") // Dark card default
  backgroundColor   String?             @default("#0f0f13") // Dark bg default
  textColor         String?             @default("#ffffff") // White text default
  accentColor       String?             @default("#fde98a") // Light gold accent
  fontFamily        String?             @default("Cairo")   // Default Arabic font
  
  // Relations
  products          Product[]
  orders            Order[]
  reservations      Reservation[]
  sessions          BotSession[]
  messages          Message[]
  whatsappSession   WhatsAppSession?
  customMenus       CustomMenu[]
  botConfig         BotConfig?

  @@map("shops")
}

model Product {
  id          String   @id @default(cuid())
  shopId      String
  name        String
  price       Float
  description String?
  imageUrl    String?  // Product image URL
  isAvailable Boolean  @default(true)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NEW FIELDS ONLY:
  stock         Int?      // null = unlimited, 0 = out of stock
  variants      String?   // JSON array of variant groups
  variantImages String?   // JSON: {"أحمر": "/uploads/red.jpg"}

  // Relations
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("products")
}

model Order {
  id             String      @id @default(cuid())
  shopId         String
  customerPhone  String
  whatsappNumber String?     // WhatsApp JID for matching
  customerName   String
  customerAddress String?
  status         OrderStatus @default(PENDING)
  totalPrice     Float
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  shop           Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  // NEW FIELD ONLY:
  variantInfo String?   // stores chosen variant as text

  // Relations
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Will be hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model BotSession {
  id        String   @id @default(cuid())
  shopId    String
  sessionId String   @unique
  status    String   @default("disconnected")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("bot_sessions")
}

model Message {
  id        String   @id @default(cuid())
  shopId    String
  from      String
  to        String
  body      String
  type      String   @default("text")
  direction Direction
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  TRIAL
  ACTIVE
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DELIVERED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SHIPPED
  CANCELLED
}

model Reservation {
  id             String            @id @default(cuid())
  shopId         String
  customerPhone  String
  whatsappNumber String?
  customerName   String?
  items          String            @db.Text  // JSON array of reserved products
  status         ReservationStatus @default(PENDING)
  totalPrice     Float
  shippingPhone  String?
  shippingAddress String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  shop           Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

enum Direction {
  INCOMING
  OUTGOING
}

model WhatsAppSession {
  id        String   @id
  shopId    String   @unique
  creds     String   @db.Text
  keys      String   @db.Text
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("whatsapp_sessions")
}

// ═══════ Custom Bot System ═══════

model CustomBotRequest {
  id          String   @id @default(cuid())
  companyName String
  industry    String
  phone       String
  message     String   @db.Text
  status      String   @default("pending") // pending | approved | rejected
  botType     String?  // null until approved, then "isp" etc.
  adminNote   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("custom_bot_requests")
}

model BotConfig {
  id                  String  @id @default(cuid())
  shopId              String  @unique
  welcomeMessage      String  @db.Text
  unknownMessage      String  @db.Text
  orderConfirmMessage String  @db.Text
  aiSystemPrompt      String  @db.Text
  aiProvider          String  @default("groq") // "groq" | "gemini"
  aiModel             String  @default("gemini-1.5-flash")
  aiTemperature       Float   @default(0.7)
  aiMaxTokens         Int     @default(300)
  customGroqApiKey    String? // Custom Groq API key for this shop
  mainMenuId          String?
  formalityLevel      Int     @default(1) // 0=casual, 1=balanced, 2=formal
  shop                Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("bot_configs")
}

model CustomMenu {
  id          String           @id @default(cuid())
  shopId      String
  name        String
  description String?
  order       Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  shop        Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items       CustomMenuItem[]

  @@map("custom_menus")
}

model CustomMenuItem {
  id          String     @id @default(cuid())
  menuId      String
  number      Int
  label       String
  price       Float?
  description String?
  action      String     // "confirm_order" | "go_to_menu" | "ai_response" | "custom_message"
  actionValue String?    @db.Text // menu id to go to, or custom message text
  aiPrompt    String?    @db.Text // custom AI instruction for this item
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  menu        CustomMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("custom_menu_items")
}
